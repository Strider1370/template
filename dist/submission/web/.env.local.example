# 카카오맵 JavaScript 키 (developers.kakao.com → 내 애플리케이션 → JavaScript 키)
# 플랫폼 > Web 사이트 도메인에 http://localhost:3000 (개발) 및 배포 도메인을 등록해야 지도가 표시됩니다.
# 이 파일을 .env.local 로 복사한 뒤 값을 채우세요. (.env.local 은 커밋 금지)
NEXT_PUBLIC_KAKAO_MAP_KEY=

# (선택) 카카오 로컬 REST API 키 — 가까운 시설 검색 프록시(/api/places)용. JS 키와 별개의 REST 키.
# 미설정 시 고정 시설 목록(facilities/*.json)으로 폴백.
KAKAO_REST_API_KEY=

# (선택) Anthropic API 키 — AI 자격 Q&A 실시간 LLM(/api/ask)용.
# 미설정 시 검증된 답변(qa.json)+규칙 브리핑으로 폴백(데모는 키 없이도 동작).
ANTHROPIC_API_KEY=
