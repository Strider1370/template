# web/.env.local.example — 복사해서 .env.local 로 쓰세요 (.env.local 은 커밋 금지)
#
# AI(자연어 입력 + 자연스러운 설명)는 선택입니다.
# 키가 없어도 데모는 폴백(드롭다운 입력 + 사전작성 설명)으로 완전히 동작합니다.
# 키가 있으면 자연어 입력 파싱과 더 자연스러운 설명이 켜집니다.
ANTHROPIC_API_KEY=

# (선택) 모델 override. 기본 claude-sonnet-4-6
# ANTHROPIC_MODEL=claude-sonnet-4-6

# (이 주제에서는 미사용 — 지도 안 씀)
# NEXT_PUBLIC_KAKAO_MAP_KEY=
