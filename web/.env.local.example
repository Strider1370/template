# web/.env.local.example — 복사해서 .env.local 로 쓰세요 (.env.local 은 커밋 금지)

# ── AI (ChatGPT/OpenAI) — 선택 ───────────────────────────────────
# 자연어 입력 파싱 · 혜택 설명 rewrite · 되묻기 문구 생성에 사용.
# 키가 없어도 데모는 폴백(드롭다운 입력 + 사전작성 설명 + 기본 질문문구)으로 완전히 동작.
OPENAI_API_KEY=
# 모델 override (기본 gpt-4.1-mini). gpt-5.x/o 시리즈도 자동 대응(max_completion_tokens).
# OPENAI_MODEL=gpt-4.1-mini

# ── 공공데이터 (보조금24 등) — 선택 ─────────────────────────────
# ① 실시간 후보 카탈로그(보조금24)에 사용. 없으면 샘플 카탈로그 폴백.
# data.go.kr 에서 발급한 URL 인코딩 키. (해당 데이터셋 '활용신청' 승인 필요)
DATA_GO_KR_KEY=

# (이 주제에서는 미사용 — 지도 안 씀)
# NEXT_PUBLIC_KAKAO_MAP_KEY=
