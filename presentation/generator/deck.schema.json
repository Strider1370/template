{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "presentation/generator/deck.schema.json",
  "title": "deck.json",
  "description": "Slidev와 정적 HTML이 함께 사용하는 단일 슬라이드 계약. 엔진별 중복 작성 금지. Doc2 §9.2.",
  "type": "object",
  "required": ["version", "meta", "slides"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "meta": {
      "type": "object",
      "required": ["title", "engine"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string" },
        "engine": {
          "type": "string",
          "description": "기본 생성 엔진. engine-registry.json의 primary와 일치(slidev).",
          "enum": ["slidev"]
        },
        "fallbackEngine": {
          "type": "string",
          "enum": ["notion-static-html"],
          "description": "백업 출력 엔진. 선택(기본 notion-static-html)."
        },
        "theme": { "type": "string", "description": "예: notion-slidev" },
        "aspectRatio": { "type": "string", "default": "16:9" },
        "language": { "type": "string", "default": "ko" },
        "totalDurationSeconds": { "type": "integer", "minimum": 0 }
      }
    },
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/slide" }
    }
  },
  "$defs": {
    "slide": {
      "type": "object",
      "required": ["id", "semanticLayout", "content"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^slide-[0-9]+$",
          "description": "예: slide-01"
        },
        "sceneId": {
          "type": "string",
          "pattern": "^scene-[0-9]+$",
          "description": "원본 scene 참조."
        },
        "role": {
          "type": "string",
          "description": "scenes.json의 role을 승계."
        },
        "semanticLayout": {
          "type": "string",
          "description": "Doc2 §8 공통 semantic layout ID. layout-registry.json에 등록된 것만 허용.",
          "enum": [
            "hero",
            "problem-flow",
            "contrast",
            "insight-statement",
            "product-overview",
            "demo-fullscreen",
            "demo-callout",
            "architecture",
            "before-after",
            "big-number",
            "card-grid",
            "timeline",
            "quote",
            "limitation-guardrail",
            "expansion-map",
            "closing"
          ]
        },
        "engineLayout": {
          "type": "string",
          "description": "실제 Slidev layout 이름(렌더러가 채움). 선택."
        },
        "referenceCapture": {
          "type": "string",
          "description": "참고 캡처 ID(밀도/리듬 기준). 선택."
        },
        "content": {
          "type": "object",
          "description": "semantic layout의 slot에 채워지는 내용. slot 이름은 layout-registry.json 참조.",
          "additionalProperties": true
        },
        "assets": {
          "type": "object",
          "description": "슬롯에 들어가는 자산 경로 맵(로컬 경로). Doc2 §17 #9: 외부 URL 금지.",
          "additionalProperties": true
        },
        "speakerNotes": {
          "type": "string",
          "description": "발표자 노트. Doc2 §11: 반드시 포함."
        },
        "durationSeconds": { "type": "integer", "minimum": 0 },
        "contentScale": {
          "type": "number",
          "minimum": 0.5,
          "maximum": 2,
          "default": 1,
          "description": "슬라이드 본문 콘텐츠 글자 배율. 미지정 시 1(변화 없음). 여백 많으면 키우고 빽빽하면 줄인다. 프레임·간격은 고정, 글자만 스케일."
        },
        "layoutReason": {
          "type": "string",
          "description": "레이아웃 선택 이유 로그. Doc2 §10."
        },
        "implementationStatus": {
          "type": "string",
          "enum": ["implemented", "mocked", "fallback", "dropped", "blocked"],
          "description": "Doc2 §11: implemented가 아니면 실제 구현처럼 표현 금지."
        },
        "claimIds": { "type": "array", "items": { "type": "string" } },
        "sourceIds": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
