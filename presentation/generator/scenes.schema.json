{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "presentation/generator/scenes.schema.json",
  "title": "scenes.json",
  "description": "발표 스크립트(script.md)를 시각 장면(scene) 단위로 분해한 중간 계약. Doc2 §9.1.",
  "type": "object",
  "required": ["version", "title", "scenes"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "title": { "type": "string", "description": "프로젝트/발표 제목" },
    "totalDurationSeconds": {
      "type": "integer",
      "minimum": 0,
      "description": "전체 발표 목표 길이(초). 선택."
    },
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/scene" }
    }
  },
  "$defs": {
    "scene": {
      "type": "object",
      "required": ["id", "role", "message"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^scene-[0-9]+$",
          "description": "예: scene-01"
        },
        "role": {
          "type": "string",
          "description": "장면의 서사적 역할. select-layouts.mjs의 규칙 기반 매핑(Doc2 §10) 입력.",
          "enum": [
            "answer-first",
            "problem",
            "insight",
            "solution",
            "product-overview",
            "demo",
            "mechanism",
            "impact",
            "limitation",
            "expansion",
            "closing"
          ]
        },
        "durationSeconds": { "type": "integer", "minimum": 0 },
        "message": {
          "type": "string",
          "description": "이 장면이 전달하는 한 문장 핵심 주장."
        },
        "script": {
          "type": "string",
          "description": "발표자가 실제로 말할 원문(speaker notes 시드)."
        },
        "visualIntent": {
          "type": "string",
          "description": "화면이 무엇을 보여줘야 하는지의 의도."
        },
        "contentType": {
          "type": "string",
          "description": "콘텐츠 형태 힌트(예: hero-message, comparison, big-number, screenshot)."
        },
        "requiredAssets": {
          "type": "array",
          "items": { "type": "string" },
          "description": "필요한 자산 ID/경로(스크린샷·녹화 등)."
        },
        "wowMoment": {
          "type": "boolean",
          "description": "킥/차별점 강조 장면이면 true. demo + wowMoment → demo-callout 등 매핑에 사용.",
          "default": false
        },
        "comparison": {
          "type": "string",
          "description": "비교 구조 힌트: assumption-reality | strong-statement | process | none.",
          "enum": ["assumption-reality", "strong-statement", "process", "none"]
        },
        "claimIds": {
          "type": "array",
          "items": { "type": "string" },
          "description": "research/sources.json과 연결되는 주장 ID. Doc2 §19.4."
        },
        "sourceIds": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
