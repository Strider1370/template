{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "stage-state.schema.json",
  "title": "workflow/state.yaml",
  "description": "현재 워크플로우 상태. 스크립트가 갱신하며, status는 정해진 enum만 허용.",
  "type": "object",
  "required": ["workflowVersion", "workflowMode", "current"],
  "properties": {
    "workflowVersion": { "type": "integer" },
    "workflowMode": { "type": "string", "enum": ["bootstrap", "run", "maintenance"] },
    "project": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "topic": { "type": "string" },
        "startedAt": { "type": ["string", "null"] },
        "deadlineMinutes": { "type": "integer" },
        "presentationMinutes": { "type": "integer" }
      }
    },
    "current": {
      "type": "object",
      "required": ["stageNumber", "stageId", "status"],
      "properties": {
        "stageNumber": { "type": "integer", "minimum": 0, "maximum": 12 },
        "stageId": { "type": "string" },
        "status": { "type": "string", "enum": ["not_started", "in_progress", "blocked", "awaiting_approval", "gate_failed", "completed"] },
        "startedAt": { "type": ["string", "null"] },
        "budgetMinutes": { "type": ["integer", "null"] }
      }
    },
    "completedStages": {
      "type": "array",
      "description": "완료된 단계 기록. 각 항목에 걸린 시간(actualMinutes)을 함께 남긴다.",
      "items": {
        "type": "object",
        "properties": {
          "stageNumber": { "type": "integer" },
          "stageId": { "type": "string" },
          "startedAt": { "type": ["string", "null"] },
          "completedAt": { "type": ["string", "null"] },
          "actualMinutes": { "type": ["number", "null"] },
          "budgetMinutes": { "type": ["integer", "null"] }
        }
      }
    },
    "requiredReads": { "type": "array", "items": { "type": "string" } },
    "activeAgents": { "type": "array" },
    "blockedBy": { "type": "array" },
    "nextGate": { "type": "object" },
    "humanApproval": {
      "type": "object",
      "properties": {
        "required": { "type": "boolean" },
        "status": { "type": "string", "enum": ["not_required", "pending", "approved", "rejected"] },
        "decisionFile": { "type": ["string", "null"] }
      }
    },
    "lastHandoff": { "type": ["string", "null"] },
    "lastSuccessfulCheckpoint": { "type": "object" },
    "contextPolicy": { "type": "object" },
    "lastUpdatedAt": { "type": ["string", "null"] }
  }
}
